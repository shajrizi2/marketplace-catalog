generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ImportRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id         String      @id @default(uuid()) @db.Uuid
  email      String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  loginCodes LoginCode[]
  sessions   Session[]
}

model LoginCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Category {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  fullPath  String     @unique
  parentId  String?    @db.Uuid
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]

  @@index([parentId])
}

model Product {
  id                  String     @id @default(uuid()) @db.Uuid
  title               String
  description         String
  sku                 String     @unique
  price               Decimal    @db.Decimal(12, 2)
  stock               Int
  categoryId          String     @db.Uuid
  lastSeenImportRunId String?    @db.Uuid
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  category            Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  lastSeenImportRun   ImportRun? @relation("LastSeenProducts", fields: [lastSeenImportRunId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([price])
  @@index([stock])
  @@index([lastSeenImportRunId])
}

model ImportRun {
  id           String             @id @default(uuid()) @db.Uuid
  sourceUrl    String
  status       ImportRunStatus    @default(PENDING)
  startedAt    DateTime           @default(now())
  finishedAt   DateTime?
  errorMessage String?
  products     Product[]          @relation("LastSeenProducts")
  stagingRows  ProductImportRow[]
}

model ProductImportRow {
  id           String    @id @default(uuid()) @db.Uuid
  importRunId  String    @db.Uuid
  title        String
  description  String
  categoryPath String
  sku          String
  price        Decimal   @db.Decimal(12, 2)
  stock        Int
  createdAt    DateTime  @default(now())
  importRun    ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([importRunId])
  @@index([sku])
  @@index([categoryPath])
}
